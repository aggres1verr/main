def count_divisors(n):
    """Подсчёт количества делителей числа n"""
    count = 0
    i = 1
    while i * i <= n:
        if n % i == 0:
            count += 1
            if i != n // i:  # избегаем двойного счёта для квадратов
                count += 1
        i += 1
    return count

