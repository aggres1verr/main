print(f"При 100 бросках:")
print(f"  0 (решка): {count_0_100} раз, частота = {count_0_100/100:.4f}")
print(f"  1 (орел):  {count_1_100} раз, частота = {count_1_100/100:.4f}")

# При 1000 бросках
