        if num % d == 0:
            divisors.append(d)
    cnt = len(divisors)
    div_str = ", ".join(map(str, divisors[:8]))
    if len(divisors) > 8:
        div_str += "..."
    print(f"{num:<8} | {div_str:<30} | {cnt}")

