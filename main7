def simulate_coin(n):
    """Подбросить монету n раз, вернуть частоты 0 и 1"""
    count_0 = 0
    count_1 = 0
    for _ in range(n):
        if random.randint(0, 1) == 0:
            count_0 += 1
        else:
            count_1 += 1
    return count_0, count_1

